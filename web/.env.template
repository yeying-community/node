# Minimal required settings.
VITE_NODE_API_ENDPOINT=http://localhost:8100
VITE_WEBDAV_BASE_URL=https://webdav.example.com

# Optional advanced overrides.
# By default, the app derives:
# - API audience from VITE_NODE_API_ENDPOINT
# - API capability as app:all:<current-host> + invoke
# - WebDAV audience from VITE_WEBDAV_BASE_URL
# - WebDAV capability as app:all:<current-host> + write
#
# VITE_UCAN_AUD=did:web:localhost:8100
# VITE_UCAN_WITH=app:all:localhost-5173
# VITE_UCAN_CAN=invoke
# VITE_UCAN_APP_ID=localhost-5173
# VITE_WEBDAV_PREFIX=/webdav
# VITE_WEBDAV_AUD=did:web:webdav.example.com
# VITE_WEBDAV_UCAN_WITH=app:all:localhost-5173
# VITE_WEBDAV_UCAN_CAN=write
# VITE_WEBDAV_PUBLIC_BASE=https://cdn.example.com/webdav
# VITE_WEBDAV_AVATAR=/avatars/default.png
